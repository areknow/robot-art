# Copy to .env in this folder (apps/ui/.env). Nx only exposes variables prefixed with NX_.
# CI: set the same variable names in your pipeline environment (no file needed).

NX_API_ENDPOINT=http://localhost:3333

NX_FIREBASE_API_KEY=
NX_FIREBASE_AUTH_DOMAIN=
NX_FIREBASE_PROJECT_ID=
NX_FIREBASE_STORAGE_BUCKET=
NX_FIREBASE_MESSAGING_SENDER_ID=
NX_FIREBASE_APP_ID=
NX_FIREBASE_DATABASE_URL=
